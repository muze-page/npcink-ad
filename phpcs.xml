<?xml version="1.0"?>
<ruleset name="Magick AD">
    <description>Magick AD WordPress coding standards.</description>

    <arg name="basepath" value="."/>
    <arg name="colors"/>
    <arg name="extensions" value="php"/>
    <arg name="parallel" value="4"/>
    <arg name="warning-severity" value="0"/>
    <arg value="sp"/>

    <file>magick-ad.php</file>
    <file>uninstall.php</file>
    <file>src</file>
    <file>tests/phpunit</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/build/*</exclude-pattern>
    <exclude-pattern>*/dist/*</exclude-pattern>

    <config name="minimum_supported_wp_version" value="6.5"/>
    <config name="testVersion" value="8.1-"/>

    <rule ref="WordPress">
        <!-- The plugin uses a PSR-4-style class tree rather than class-*.php files. -->
        <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
        <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
    </rule>

    <rule ref="WordPress.WP.Capabilities">
        <properties>
            <property name="custom_capabilities" type="array">
                <element value="manage_magick_ads"/>
            </property>
        </properties>
    </rule>
</ruleset>
