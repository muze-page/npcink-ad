{
    "name": "magick-ad/wp-plugin",
    "type": "wordpress-plugin",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "phpstan/phpstan": "^1.11",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "vimeo/psalm": "^5.26",
        "wp-coding-standards/wpcs": "^3.0"
    },
    "scripts": {
        "lint:phpcs": "phpcs -p",
        "lint:phpstan": "phpstan analyse -c phpstan.neon",
        "lint:psalm": "psalm --no-progress"
    }
}
