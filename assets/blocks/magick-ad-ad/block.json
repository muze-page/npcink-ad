{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "magick-ad/ad",
    "title": "Magick AD（广告位）",
    "category": "widgets",
    "icon": "megaphone",
    "description": "在文章或模板中插入一个 Magick AD 广告位入口。",
    "textdomain": "magick-ad",
    "editorScript": "magick-ad-block-editor",
    "editorStyle": "magick-ad-block-editor",
    "supports": {
        "html": false,
        "anchor": true,
        "align": [
            "wide",
            "full"
        ]
    },
    "attributes": {
        "placementId": {
            "type": "integer",
            "default": 0
        },
        "reserveHeight": {
            "type": "integer",
            "default": 0
        },
        "preview": {
            "type": "boolean",
            "default": true
        }
    }
}
