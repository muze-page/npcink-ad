{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "npcink-ad/promotion",
    "title": "Npcink Ad Promotion",
    "category": "widgets",
    "icon": "megaphone",
    "description": "Insert a manually placed Npcink Ad promotion.",
    "textdomain": "npcink-ad",
    "editorScript": "npcink-ad-block-editor",
    "editorStyle": "npcink-ad-block-editor",
    "supports": {
        "html": false,
        "anchor": true,
        "align": [
            "wide",
            "full"
        ]
    },
    "attributes": {
        "promotionId": {
            "type": "integer",
            "default": 0
        },
        "reserveHeight": {
            "type": "integer",
            "default": 0
        },
        "preview": {
            "type": "boolean",
            "default": true
        }
    }
}
